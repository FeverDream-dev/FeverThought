{
  "name": "feverthoth-ide",
  "version": "0.1.0",
  "private": true,
  "description": "FeverThoth IDE - AI-first Rust-based desktop IDE",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter @feverthoth/desktop dev",
    "build": "pnpm --filter @feverthoth/desktop build",
    "tauri": "pnpm --filter @feverthoth/desktop tauri",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
